# Rael School — environment variables (šablona)
# Zkopíruj na .env a doplň reálné hodnoty: cp .env.example .env

# Cesta k SQLite databázi (relativní k rootu projektu)
DATABASE_URL="file:./dev.db"

# JWT secret pro podepisování auth cookies.
# Vygeneruj silný secret (min 32 znaků, bez slov rael/school/secret/password/test/demo):
#   openssl rand -base64 32
# Slabý secret je detekován za běhu (varování v logu) — viz src/lib/auth.ts
JWT_SECRET="CHANGE-ME-openssl-rand-base64-32"
